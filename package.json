{
  "name": "opengecko",
  "version": "0.5.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "description": "CoinGecko-compatible open-source API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:endpoint": "bash scripts/test-endpoints.sh",
    "test:endpoint:assets": "bash scripts/modules/assets/assets.sh",
    "test:endpoint:coins": "bash scripts/modules/coins/coins.sh",
    "test:endpoint:exchanges": "bash scripts/modules/exchanges/exchanges.sh",
    "test:endpoint:global": "bash scripts/modules/global/global.sh",
    "test:endpoint:mr-market-frontend": "bash scripts/modules/mr-market-frontend/mr-market-frontend.sh",
    "test:endpoint:search": "bash scripts/modules/search/search.sh",
    "test:endpoint:simple": "bash scripts/modules/simple/simple.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "charts:backfill": "tsx src/jobs/backfill-ohlcv.ts",
    "ohlcv:worker": "tsx src/jobs/run-ohlcv-worker.ts",
    "search:rebuild": "tsx src/jobs/rebuild-search-index.ts",
    "markets:refresh": "tsx src/jobs/refresh-market-snapshots.ts",
    "coingecko:snapshots:capture": "tsx src/jobs/capture-coingecko-snapshots.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "ccxt": "^4.4.81",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
