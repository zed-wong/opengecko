{
  "name": "opengecko",
  "version": "0.2.1",
  "private": true,
  "packageManager": "bun@1.3.9",
  "description": "CoinGecko-compatible open-source API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "charts:backfill": "tsx src/jobs/backfill-ohlcv.ts",
    "search:rebuild": "tsx src/jobs/rebuild-search-index.ts",
    "markets:refresh": "tsx src/jobs/refresh-market-snapshots.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "ccxt": "^4.4.81",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
